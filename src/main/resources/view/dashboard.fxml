<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.bloodblank.controller.DashboardController"
            style="-fx-background-color: #1a1a2e;" prefWidth="900" prefHeight="600">

    <stylesheets>
        <URL value="@/style.css" />
    </stylesheets>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 20; -fx-background-color: #16213e;">
            <Label text="BloodBank" style="-fx-text-fill: #e94560; -fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="usernameLabel" text="Halo, User" style="-fx-text-fill: white; -fx-font-size: 16px;"/>
            <Button text="Logout" onAction="#handleLogout" styleClass="button" />
        </HBox>
    </top>

    <center>
        <StackPane fx:id="contentArea">
            <VBox fx:id="buttonContainer" alignment="CENTER" spacing="30">
                <Label text="Apa yang ingin Anda lakukan hari ini?" style="-fx-font-size: 28px; -fx-text-fill: white; -fx-font-weight: bold;"/>
                <HBox alignment="CENTER" spacing="30">
                    <Button text="MENDONOR" onAction="#handleDonor" prefWidth="250" prefHeight="120" styleClass="button-hijau" />
                    <Button text="BUTUH DARAH" onAction="#handleNeed" prefWidth="250" prefHeight="120" styleClass="button-hijau" />
                </HBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>