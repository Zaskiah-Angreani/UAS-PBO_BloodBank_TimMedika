<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.bloodblank.controller.RegisterController"
           style="-fx-background-color: #1a1a2e;">

    <stylesheets>
        <URL value="@/style.css" />
    </stylesheets>

    <VBox alignment="CENTER" spacing="15.0" maxWidth="400">
        <Label text="Form Registrasi" styleClass="header-label"/>

        <VBox spacing="5">
            <TextField fx:id="usernameField" promptText="Username" />
            <Label fx:id="userErrorLabel" style="-fx-text-fill: #e94560; -fx-font-size: 12px; -fx-font-style: italic;" visible="false" managed="false"/>
        </VBox>
        <VBox spacing="5">
            <PasswordField fx:id="passwordField" promptText="Password" />
            <Label fx:id="passErrorLabel" style="-fx-text-fill: #e94560; -fx-font-size: 12px; -fx-font-style: italic;" visible="false" managed="false"/>
        </VBox>
        <VBox spacing="5">
            <PasswordField fx:id="confirmPasswordField" promptText="Konfirmasi Password" />
            <Label fx:id="confirmPassErrorLabel" style="-fx-text-fill: #e94560; -fx-font-size: 12px; -fx-font-style: italic;" visible="false" managed="false"/>
        </VBox>

        <Button text="Daftar" onAction="#handleRegister" prefWidth="300" styleClass="button"/>
        <Button text="Kembali ke Login" onAction="#handleBackToLogin" styleClass="link-button" prefWidth="300"/>
    </VBox>
</StackPane>