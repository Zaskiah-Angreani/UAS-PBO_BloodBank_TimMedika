<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.bloodblank.controller.RegisterController"
           style="-fx-background-color: #1a1a2e;">

    <stylesheets>
        <URL value="@/style.css" />
    </stylesheets>

    <VBox alignment="CENTER" spacing="20.0" maxWidth="400" maxHeight="400">
        <Label text="Form Registrasi" styleClass="header-label"/>

        <TextField fx:id="usernameField" promptText="Username" styleClass="input-field"/>
        <PasswordField fx:id="passwordField" promptText="Password" styleClass="input-field"/>
        <PasswordField fx:id="confirmPasswordField" promptText="Konfirmasi Password" styleClass="input-field"/>

        <Button text="Daftar" onAction="#handleRegister" prefWidth="300" styleClass="button"/>
        <Button text="Kembali ke Login" onAction="#handleBackToLogin" styleClass="link-button" prefWidth="300"/>
    </VBox>
</StackPane>