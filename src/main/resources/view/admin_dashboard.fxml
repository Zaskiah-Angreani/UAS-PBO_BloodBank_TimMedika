<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane style="-fx-background-color: #1a1a2e; -fx-padding: 0;"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.bloodblank.controller.AdminController">

    <top>
        <HBox style="-fx-background-color: #232946; -fx-padding: 15;" alignment="CENTER_LEFT">
            <Label text="Admin Dashboard" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Logout" onAction="#handleLogout" style="-fx-background-color: #e94560; -fx-text-fill: white;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="20" style="-fx-padding: 20;">
            <VBox spacing="10" style="-fx-background-color: #232946; -fx-padding: 15; -fx-background-radius: 10;">
                <Label text="Manajemen Stok Darah (Klik Jumlah untuk Edit)" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                <TableView fx:id="tabelStok" prefHeight="200">
                    <columns>
                        <TableColumn fx:id="colGol" text="Golongan" prefWidth="100"/>
                        <TableColumn fx:id="colRS" text="Rumah Sakit" prefWidth="250"/>
                        <TableColumn fx:id="colJumlah" text="Jumlah" prefWidth="100"/>
                    </columns>
                </TableView>
            </VBox>

            <VBox spacing="10" style="-fx-background-color: #232946; -fx-padding: 15; -fx-background-radius: 10;">
                <Label text="Verifikasi Pengajuan User" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                <TableView fx:id="tabelRequest" prefHeight="200">
                    <columns>
                        <TableColumn fx:id="colPasien" text="Pasien" prefWidth="150"/>
                        <TableColumn fx:id="colStatusRequest" text="Status" prefWidth="150"/>
                    </columns>
                </TableView>
                <HBox spacing="10">
                    <Button text="Setujui" onAction="#handleSetuju" style="-fx-background-color: #4caf50; -fx-text-fill: white;"/>
                    <Button text="Tolak" onAction="#handleTolak" style="-fx-background-color: #e94560; -fx-text-fill: white;"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>